
{
  "entities": {
    "UserAccount": {
      "title": "User Account",
      "description": "System user account data for students, teachers, and admins.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student", "teacher"] },
        "status": { "type": "string", "enum": ["active", "suspended", "pending"] },
        "phoneNumber": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "status"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment application data.",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "gender": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "religion": { "type": "string" },
        "fatherName": { "type": "string" },
        "fatherOccupation": { "type": "string" },
        "motherName": { "type": "string" },
        "motherOccupation": { "type": "string" },
        "academicYear": { "type": "string" },
        "standard": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "institutionName": { "type": "string" },
        "board": { "type": "string" },
        "batchTiming": { "type": "string" },
        "feesDetails": { "type": "string" },
        "admissionDate": { "type": "string", "format": "date" },
        "admissionNo": { "type": "string" },
        "fatherNo": { "type": "string" },
        "motherNo": { "type": "string" },
        "whatsappNo": { "type": "string" },
        "residentialAddress": { "type": "string" },
        "status": { "type": "string", "enum": ["Active", "pending", "Completed", "Dropped"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "admissionNo"]
    },
    "Course": {
      "title": "Course",
      "description": "Academy course offerings and details.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "level": { "type": "string" },
        "price": { "type": "string" },
        "duration": { "type": "string" },
        "hasCertificate": { "type": "boolean" },
        "isPublished": { "type": "boolean" },
        "modules": { "type": "array", "items": { "type": "string" } },
        "students": { "type": "number" },
        "rating": { "type": "number" },
        "status": { "type": "string", "enum": ["Active", "Draft"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "duration"]
    },
    "StudyMaterial": {
      "title": "Study Material",
      "description": "Educational resources available for download.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "grade": { "type": "string" },
        "board": { "type": "string", "enum": ["CBSE", "Samacheer"] },
        "pdfUrl": { "type": "string" },
        "subject": { "type": "string" },
        "isVisible": { "type": "boolean" },
        "allowDownloads": { "type": "boolean" }
      },
      "required": ["title", "category", "grade", "board"]
    },
    "TimetableEntry": {
      "title": "Timetable Entry",
      "description": "Daily schedule data for offline classes.",
      "type": "object",
      "properties": {
        "board": { "type": "string", "enum": ["cbse", "samacheer"] },
        "grade": { "type": "string" },
        "day": { "type": "string" },
        "timeSlot": { "type": "string" },
        "subject": { "type": "string" },
        "teacher": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["board", "grade", "day", "timeSlot", "subject"]
    },
    "TopPerformer": {
      "title": "Top Performer",
      "description": "Student achievement data for the results page.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "marks": { "type": "string" },
        "rank": { "type": "string" },
        "year": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "marks", "year"]
    },
    "PageContent": {
      "title": "Page Content",
      "description": "Dynamic content for various pages of the website.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserAccount" },
      "description": "Collection of system user accounts."
    },
    "/enrollments/{enrollmentId}": {
      "schema": { "$ref": "#/entities/Enrollment" },
      "description": "Collection of student applications."
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "#/entities/Course" },
      "description": "Collection of available courses."
    },
    "/study-materials/{materialId}": {
      "schema": { "$ref": "#/entities/StudyMaterial" },
      "description": "Collection of downloadable study resources."
    },
    "/timetables/{entryId}": {
      "schema": { "$ref": "#/entities/TimetableEntry" },
      "description": "Collection of class schedules."
    },
    "/top-performers/{performerId}": {
      "schema": { "$ref": "#/entities/TopPerformer" },
      "description": "Collection of top performing students."
    },
    "/pages/{pageId}": {
      "schema": { "$ref": "#/entities/PageContent" },
      "description": "Dynamic content for website pages."
    }
  }
}
