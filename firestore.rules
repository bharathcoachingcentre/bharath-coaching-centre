rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /enrollments/{docId} {
      allow read, write: if true;
    }

    match /courses/{courseId} {
      allow read, write: if true;
    }

    match /study-materials/{materialId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if true;
    }

    match /pages/{pageId} {
      allow read, write: if true;
    }

    match /timetables/{timetableId} {
      allow read, write: if true;
    }

    match /recovery-bin/{itemId} {
      allow read, write: if true;
    }

    match /years/{yearId} {
      allow read, write: if true;
    }

    match /top-performers/{id} {
      allow read, write: if true;
    }

    match /classes/{id} {
      allow read, write: if true;
    }

    match /subjects/{id} {
      allow read, write: if true;
    }

    match /periods/{id} {
      allow read, write: if true;
    }

    match /material-leads/{leadId} {
      allow read, write: if true;
    }

    match /blogs/{blogId} {
      allow read, write: if true;
    }

  }
}