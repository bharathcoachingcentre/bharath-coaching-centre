
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Enrollments: Allow public creation for student registrations and general access for admin management
    match /enrollments/{enrollmentId} {
      allow read, write: if true;
    }
    
    // Study Materials: Allow public read access so students can download resources
    match /study-materials/{materialId} {
      allow read: if true;
      allow write: if true; // Open for initial setup/admin management
    }
    
    // Top Performers: Allow public read access for the results page
    match /top-performers/{performerId} {
      allow read: if true;
      allow write: if true; // Open for initial setup/admin management
    }
  }
}
